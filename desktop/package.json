{
  "name": "cityrail-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "CityRail desktop launcher that keeps the installed client synchronized with cityrailgame.com.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.cityrail.desktop",
    "productName": "CityRail 轨道交通模拟器",
    "asar": true,
    "files": [
      "src/**",
      "package.json"
    ],
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://cityrailgame.com/releases/desktop/"
      }
    ]
  }
}
